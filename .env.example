# ─── TiO2 Monitor — Environment Variables ───────────────────────────────────
# Копирай този файл като .env и попълни стойностите за локално тестване.
# В GitHub добави тези стойности като Secrets (Settings → Secrets → Actions).
# НИКОГА не качвай .env файла в GitHub!

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Вземи от: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail (за изпращане на email) ────────────────────────────────────────────
# Gmail адресът от който се изпраща докладът
GMAIL_USER=your-sender@gmail.com

# App Password (НЕ е паролата за Gmail!)
# Как да го генерираш: Google Акаунт → Сигурност → 2-Step → App Passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email адрес на получателя
RECIPIENT_EMAIL=ppetrov@petrex.bg

# ── Google Service Account (за Sheets + Drive) ───────────────────────────────
# JSON credentials от Google Cloud Console:
# 1. console.cloud.google.com → APIs & Services → Credentials
# 2. Create Service Account → Download JSON
# 3. Постави целия JSON като един ред (без нови редове)
# 4. В Sheets/Drive → Share → добави email-а на service account-а
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"tio2-monitor@project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── Google Sheets IDs ─────────────────────────────────────────────────────────
# ID на "TiO2 Monitor — История на докладите"
SHEETS_HISTORY_ID=1hIS_KRRCTVzA-g-KeBM2dnSWlwPnWMMw3l2YW2tPF60

# ID на "TiO2 Monitor — Архив на Доклади"
SHEETS_ARCHIVE_ID=1jMDLrPRZgTG_O6CwdoX8EP5ev52bUrbTWeW9MYKAvdM

# ── Опционални настройки ──────────────────────────────────────────────────────
# Брой дни назад за търсене (по подразбиране: 7)
DAYS_BACK=7
